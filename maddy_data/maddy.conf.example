# --- Macros (Variables) ---
# Replace these with your actual domain details
$(hostname) = mx.example.com
$(primary_domain) = example.com

# --- Global Directives ---
state_dir /data
runtime_dir /run/maddy

hostname $(hostname)
autogenerated_msg_domain $(primary_domain)

# TLS Certificates (Usually managed by Certbot or acme.sh)
tls file /data/tls/fullchain.pem /data/tls/privkey.pem

# --- 1. Storage & Auth ---
# Using SQLite for a lightweight, self-contained setup
auth.pass_table local_authdb {
    table sql_table {
        driver sqlite3
        dsn /data/maddy.db
        table_name credentials
    }
}

storage.imapsql local_mailboxes {
    driver sqlite3
    dsn /data/maddy.db
}

# --- 2. Delivery Logic (Incoming) ---
# Routes mail addressed to your domain to the local storage
msgpipeline local_routing {
    destination $(primary_domain) {
        deliver_to &local_mailboxes
    }
    default_destination {
        reject 550 5.1.1 "User not found"
    }
}

# --- 3. Delivery Logic (Outgoing with DKIM) ---
# Signs outgoing mail with DKIM before sending to the internet
msgpipeline remote_signing {
    modify {
        # Format: dkim <domain> <selector> <key_path>
        dkim $(primary_domain) default /data/dkim_keys/$(primary_domain)/default.key
    }
    deliver_to remote
}

# --- 4. SMTP Receiving (Port 25) ---
# External mail servers deliver mail to you here
smtp tcp://0.0.0.0:25 {
    default_source {
        deliver_to &local_routing
    }
}

# --- 5. Submission (Sending) ---
# Your email clients connect here to send mail
submission tls://0.0.0.0:465 tcp://0.0.0.0:587 {
    auth &local_authdb
    default_source {
        check {
            authorize_sender
        }
        deliver_to &remote_signing
    }
}

# --- 6. IMAP Access ---
# Your email clients connect here to read mail
imap tls://0.0.0.0:993 tcp://0.0.0.0:143 {
    auth &local_authdb
    storage &local_mailboxes
}

# --- 7. Monitoring ---
# Exposes metrics for healthchecks (Prometheus format)
openmetrics tcp://127.0.0.1:9749 {
    allow_from 127.0.0.1
}